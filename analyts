// =====================================================
// RISK ENGINE
// =====================================================

function calculateRisk(findings) {

  let score = 0

  for (let f of findings) {

    switch(f.severity) {
      case "critical": score += 50; break
      case "high": score += 25; break
      case "medium": score += 10; break
      default: score += 5
    }
  }

  let level = "LOW"

  if (score >= 120) level = "CRITICAL"
  else if (score >= 70) level = "HIGH"
  else if (score >= 35) level = "MEDIUM"

  return {
    score,
    level
  }
}

// =====================================================
// HTML REPORT
// =====================================================

function buildHTML(findings, risk) {

  let html = `
  <html>
  <head>
  <style>
    body {
      background: #111;
      color: white;
      font-family: Arial;
      padding: 20px;
    }

    .card {
      background: #1d1d1d;
      border-radius: 12px;
      padding: 15px;
      margin-bottom: 10px;
    }

    .risk {
      font-size: 28px;
      font-weight: bold;
    }
  </style>
  </head>
  <body>

  <h1>KellerSS Advanced Analyzer</h1>

  <div class="card">
    <div class="risk">RISK: ${risk.level}</div>
    <div>Score: ${risk.score}</div>
  </div>
  `

  for (let item of findings) {

    html += `
    <div class="card">
      <h3 style="color:${severityColor(item.severity)}">
        ${item.severity.toUpperCase()}
      </h3>

      <b>${item.type}</b>
      <p>${item.reason}</p>
    </div>
    `
  }

  html += `</body></html>`

  return html
}

// =====================================================
// RESULT VIEW
// =====================================================

async function showResult(html) {

  let web = new WebView()

  await web.loadHTML(html)

  await web.present()
}

// =====================================================
// MAIN
// =====================================================

async function main() {

  let step1 = new Alert()

  step1.title = "📋 Selecione o relatório"
  step1.message = "Selecione o arquivo App_Privacy_Report.ndjson"

  step1.addAction("Selecionar")
  step1.addCancelAction("Cancelar")

  if (await step1.present() === -1) {
    Script.complete()
    return
  }

  let path1 = await DocumentPicker.openFile()

  if (!path1) {
    Script.complete()
    return
  }

  let content1 = await readFile(path1)

  if (!content1) {

    let a = new Alert()

    a.title = "Erro"
    a.message = "Falha ao ler arquivo"

    a.addAction("OK")

    await a.present()

    return
  }

  let entries = parseNdjson(content1)

  let findings = []

  findings.push(...detectCheats(entries))
  findings.push(...detectVpn(entries))
  findings.push(...analyzeNetwork(entries))
  findings.push(...detectJailbreak(content1))
  findings.push(...detectInjection(content1))

  let risk = calculateRisk(findings)

  let html = buildHTML(findings, risk)

  await showResult(html)
}

await main()
