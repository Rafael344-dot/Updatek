// =====================================================
// LOGGER
// =====================================================

function log(msg) {
  if (CONFIG.DEBUG) {
    console.log(`[${CONFIG.NAME}] ${msg}`)
  }
}

// =====================================================
// HELPERS
// =====================================================

async function readFile(path) {
  try {
    return fm.readString(path)
  } catch(e) {
    console.error(e)
    return null
  }
}

function safeLower(str) {
  return (str || "").toLowerCase()
}

function severityColor(level) {
  switch(level) {
    case "critical": return "#ff0000"
    case "high": return "#ff6600"
    case "medium": return "#ffaa00"
    default: return "#00cc66"
  }
}

function checksum(str) {
  let hash = 0

  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i)
    hash |= 0
  }

  return hash
}

// =====================================================
// FILE TYPE DETECTION
// =====================================================

function looksLikePrivacyReport(content) {
  return content.includes("bundleID") ||
         content.includes("networkActivity") ||
         content.includes("domain")
}

function looksLikeUsageFile(content) {
  return content.includes("roots_installed") ||
         content.includes("os_version") ||
         content.includes("incident")
}

// =====================================================
// NDJSON PARSER
// =====================================================

function parseNdjson(content) {

  let lines = content.split("\n")
  let out = []

  for (let line of lines) {

    line = line.trim()

    if (!line) continue

    try {
      out.push(JSON.parse(line))
    } catch(e) {}
  }

  return out
}

// =====================================================
// IPS PARSER
// =====================================================

function parseIpsFile(content) {

  try {

    let lines = content.split("\n")

    let header = {}

    try {
      header = JSON.parse(lines[0])
    } catch(e) {}

    return {
      header,
      raw: content
    }

  } catch(e) {

    return {
      header: {},
      raw: content
    }
  }
}

// =====================================================
// JAILBREAK DETECTION
// =====================================================

const jailbreakArtifacts = [
  "/Applications/Cydia.app",
  "/var/jb",
  "/Library/MobileSubstrate",
  "/usr/lib/TweakInject",
  "/private/preboot",
  "dopamine",
  "palera1n",
  "ellekit",
  "substitute",
  "frida"
]

function detectJailbreak(text) {

  let findings = []

  for (let item of jailbreakArtifacts) {

    if (safeLower(text).includes(safeLower(item))) {

      findings.push({
        severity: "critical",
        type: "jailbreak",
        reason: `Jailbreak artifact encontrado: ${item}`
      })
    }
  }

  return findings
}

// =====================================================
// VPN / PROXY DETECTION
// =====================================================

const vpnKeywords = [
  "wireguard",
  "openvpn",
  "shadowrocket",
  "quantumult",
  "surge",
  "adguard",
  "clash",
  "proxy",
  "vpn"
]

function detectVpn(entries) {

  let findings = []

  for (let entry of entries) {

    let raw = JSON.stringify(entry).toLowerCase()

    for (let vpn of vpnKeywords) {

      if (raw.includes(vpn)) {

        findings.push({
          severity: "high",
          type: "vpn",
          reason: `VPN/Proxy detectado: ${vpn}`
        })
      }
    }
  }

  return findings
}

